# All variables are optional — only needed when you enable the matching
# integration in site.config.ts. With everything empty, the site still
# builds and renders placeholder-aware blocks.

# GitHub (star badges). Public API works without a token, but a PAT
# raises your rate limit when developing.
# GITHUB_TOKEN=

# Last.fm now-playing block
# LASTFM_API_KEY=

# Supabase (not wired by default; reserved for your own routes)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sentry (not wired by default; reserved for your own integration)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
